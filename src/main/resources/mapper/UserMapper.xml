<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.hrstarter.mapper.UserMapper">

    <!-- 更新用戶資訊 (根據 id ) -->
    <update id="update" parameterType="com.example.hrstarter.entity.User">
        UPDATE users
        SET
            username = #{username},
            password = #{password},
            full_name = #{fullName},
            enabled = #{enabled}
        WHERE
            id = #{id}
    </update>

    <!-- 根據 username 查找 -->
    <select id="findByUsername" resultType="com.example.hrstarter.entity.User">
        SELECT * FROM users WHERE username = #{username}
    </select>

    <!-- 插入用戶 -->
    <insert id="insert" parameterType="com.example.hrstarter.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users(username, password, full_name, enabled)
        VALUES(#{username}, #{password}, #{fullName}, #{enabled})
    </insert>

    <!-- 根據 id 查找 -->
    <select id="findById" resultType="com.example.hrstarter.entity.User">
        SELECT * FROM users WHERE id = #{id}
    </select>

     <!--查找所有用戶-->
    <select id="findAll" resultType="com.example.hrstarter.entity.User">
        SELECT *
        FROM users
    </select>
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM users
    </select>

    <!-- 刪除用戶 (根據 id) -->
    <delete id="delete" parameterType="long">
        DELETE FROM users WHERE id = #{id}
    </delete>
</mapper>
