<!--                 LEFT JOIN roles r ON ur.role_id = r.id-->
<!--        WHERE u.id = #{id}-->
<!--    </select>-->
    <!-- 更新用戶資訊 (根據 id ) -->


    <update id="updateBaseInfo">
        UPDATE users
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="fullName != null">full_name = #{fullName},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            <choose>
                <when test="employeeNo != null and employeeNo != ''">
                    employee_id = #{employeeNo},
                </when>
                <otherwise>
                    employee_id = NULL,
                </otherwise>
            </choose>
            <if test="password != null and password != ''">password = #{password},</if>
            version = version + 1,
            updated_at = NOW(),
        </set>
        WHERE id = #{id}
        <if test="version != null">
            AND version = #{version}
        </if>
    </update>

    <!-- 根據 username 查找 -->
    <select id="findByUsername" resultType="com.example.hrstarter.entity.User">
        SELECT *
        FROM users
        WHERE username = #{username}
    </select>

    <!-- 插入用戶 -->
    <insert id="insert" parameterType="com.example.hrstarter.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users(username, password, full_name, enabled, employee_id)
        VALUES (#{username}, #{password}, #{fullName}, #{enabled}, #{employeeId})
    </insert>

    <!-- 根據 id 查找 -->
    <select id="findById" resultType="com.example.hrstarter.entity.User">
        SELECT *
        FROM users
        WHERE id = #{id}
    </select>

    <!--查找所有用戶-->
    <select id="findAll" resultType="com.example.hrstarter.entity.User">
        SELECT *
        FROM users
    </select>
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM users
    </select>

    <!-- 刪除用戶 (根據 id) -->
    <delete id="delete" parameterType="long">
        DELETE
        FROM users
        WHERE id = #{id}
    </delete>


</mapper>
