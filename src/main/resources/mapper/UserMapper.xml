<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.hrstarter.mapper.UserMapper">
    <resultMap id="RoleMap" type="com.example.hrstarter.entity.Role" autoMapping="true">
        <id property="id" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleKey" column="role_key"/>
    </resultMap>

    <resultMap id="UserDetailDTOFullMap" type="com.example.hrstarter.dto.UserDetailDTO" autoMapping="true">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="fullName" column="full_name"/>
        <result property="enabled" column="enabled"/>
        <result property="employeeNo" column="employee_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <collection property="roles" resultMap="RoleWithPermsMap"/>
    </resultMap>

    <resultMap id="PermissionMap" type="com.example.hrstarter.entity.Permission">
        <id property="id" column="perm_id"/>
        <result property="permissionCode" column="permission_code"/>
        <result property="permissionName" column="permission_name"/>
        <result property="parentId" column="perm_parent_id"/>
    </resultMap>

    <resultMap id="RoleWithPermsMap" type="com.example.hrstarter.entity.Role">
        <id property="id" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleKey" column="role_key"/>
        <collection property="permissions" resultMap="PermissionMap"/>
    </resultMap>

    <select id="findByIdWithRolesAndPermissions" resultMap="UserDetailDTOFullMap">
        SELECT
            -- User 基礎資料
            u.id,
            u.username,
            u.full_name,
            u.enabled,
            u.employee_id,
            u.created_at,
            u.updated_at,

            -- Role 角色資料
            r.id AS role_id,
            r.role_name,
            r.role_key,

            -- Permission 權限資料
            p.id AS perm_id,
            p.permission_code,
            p.permission_name,
            p.parent_id AS perm_parent_id
        FROM users u
                 LEFT JOIN user_roles ur ON u.id = ur.user_id
                 LEFT JOIN roles r ON ur.role_id = r.id
                 LEFT JOIN role_permissions rp ON r.id = rp.role_id
                 LEFT JOIN permissions p ON rp.permission_id = p.id
        WHERE u.id = #{id}
    </select>

