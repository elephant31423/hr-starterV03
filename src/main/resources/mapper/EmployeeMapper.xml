<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.hrstarter.mapper.EmployeeMapper">

    <!-- 根據 username 查找 -->
    <select id="findByUsername" resultType="com.example.hrstarter.entity.Employee">
        SELECT * FROM employee WHERE username = #{username}
    </select>

    <!-- 插入員工 -->
    <insert id="insert" parameterType="com.example.hrstarter.entity.Employee" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO employee(name, phone, email, title, emp_no, resign_date, hire_date)
        VALUES (#{name}, #{phone}, #{email}, #{title}, #{empNo}, #{resignDate}, #{hireDate})
    </insert>

    <!-- 根據 id 查找 -->
    <select id="findById" resultType="com.example.hrstarter.entity.Employee">
        SELECT * FROM employee WHERE id = #{id}
    </select>

    <!-- 更新員工資訊 (根據 id) -->
    <update id="update" parameterType="com.example.hrstarter.entity.Employee">
        UPDATE employee
        SET
            name = #{ name},
            phone = #{phone},
            email = #{email},
            title = #{title},
            emp_no = #{empNo},
            status = #{status}
        WHERE
            id = #{id}
    </update>

    <!-- 刪除員工 (根據 id) -->
    <delete id="delete" parameterType="long">
        DELETE FROM employee WHERE id = #{id}
    </delete>

    <!-- 查找所有員工 -->
    <select id="findAll" resultType="com.example.hrstarter.entity.Employee">
        SELECT * FROM employee
    </select>

    <!-- 根據員工姓名模糊查找 -->
    <select id="findByEmployeeName" resultType="com.example.hrstarter.entity.Employee">
        SELECT * FROM employee WHERE full_name LIKE CONCAT('%', #{fullName}, '%')
    </select>
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM employee
    </select>

    <select id="findBirthday" resultType="java.time.LocalDate">
        SELECT birthday FROM employee WHERE id = #{id}
    </select>
    <select id="findByDepartmentId" resultType="com.example.hrstarter.entity.Employee">
        SELECT *
        FROM employee e
        <where>
            <if test="departmentId != null">
                AND e.department_id = #{departmentId}
            </if>
        </where>
        order by e.id
    </select>
    <select id="findAllActive" resultType="com.example.hrstarter.entity.Employee">
        SELECT *
        FROM employee e
        WHERE e.status =  1
        order by e.id
    </select>


</mapper>
