<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hrstarter.mapper.OvertimeRequestMapper">
    <resultMap id="OvertimeRequestMap" type="com.example.hrstarter.entity.OvertimeRequest">
        <id property="id" column="id"/>
        <result property="employeeId" column="employee_id"/>
        <result property="overtimeDate" column="overtime_date"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="hours" column="hours"/>
        <result property="reason" column="reason"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="employeeName" column="employee_name"/>
        <result property="departmentId" column="department_id"/>
        <result property="departmentName" column="department_name"/>
    </resultMap>

    <sql id="OvertimeColumns">
        ot.*,
        e.name AS employee_name,
        e.department_id,
        d.name AS department_name
    </sql>

    <select id="findDetailById" resultMap="OvertimeRequestMap">
        SELECT <include refid="OvertimeColumns"/>
        FROM overtime_requests ot
        LEFT JOIN employee e ON ot.employee_id = e.id
        LEFT JOIN departments d ON e.department_id = d.id
        WHERE ot.id = #{id}
    </select>

    <select id="findByEmployeeId" resultMap="OvertimeRequestMap">
        SELECT <include refid="OvertimeColumns"/>
        FROM overtime_requests ot
        LEFT JOIN employee e ON ot.employee_id = e.id
        LEFT JOIN departments d ON e.department_id = d.id
        WHERE ot.employee_id = #{employeeId}
        ORDER BY ot.overtime_date DESC, ot.created_at DESC
    </select>

    <select id="findAll" resultMap="OvertimeRequestMap">
        SELECT <include refid="OvertimeColumns"/>
        FROM overtime_requests ot
        LEFT JOIN employee e ON ot.employee_id = e.id
        LEFT JOIN departments d ON e.department_id = d.id
        ORDER BY ot.created_at DESC
    </select>

    <update id="updateStatus">
        UPDATE overtime_requests
        SET status = #{status}
        WHERE id = #{id}
    </update>
</mapper>
